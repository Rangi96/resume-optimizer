# Environment Variables Template
# Copy this to .env.local for development, .env.production for production

# Development
VITE_API_URL=http://localhost:3000/api

# Production (set in Vercel dashboard)
# VITE_API_URL=https://yourdomain.com/api

# Backend API Keys (Vercel Environment Variables only, never in frontend)
# ANTHROPIC_API_KEY=sk-ant-xxx
# STRIPE_SECRET_KEY=sk_live_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# DATABASE_URL=your-db-connection-string

# Frontend Configuration
# VITE_STORAGE_PROVIDER=firestore
# VITE_FIREBASE_API_KEY=your_api_key_here
# VITE_FIREBASE_AUTH_DOMAIN=your_auth_domain_here
# VITE_FIREBASE_PROJECT_ID=your_project_id_here
# VITE_FIREBASE_STORAGE_BUCKET=your_storage_bucket_here

# Development mode - bypasses payment requirements for testing
# Set to 'true' in local .env for development, false or unset in production
# VITE_DEV_MODE=false